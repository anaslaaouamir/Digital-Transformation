    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nreturn item.attachmentUrls.map(url => ({\n  json: {\n    email: item.email,\n    content: item.content,\n    attachmentUrl: url,\n    fileName: url.split('/').pop()\n  }\n}));"
      },

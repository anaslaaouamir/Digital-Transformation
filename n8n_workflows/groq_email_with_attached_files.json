      "id": "549f6fb5-5787-413e-a338-6beae6fb4fc5",
      "name": "Normalize Response"
    },
    {
      "parameters": {
        "jsCode": "const body = $('Webhook').item.json.body;\nconst content = $input.first().json.content;\nconst pixelHtml = body.pixelHtml || '';\n\n// Parse the AI generated body and append pixel\nconst parsed = JSON.parse(content[0].text);\nconst finalBody = parsed.body + '<br>' + pixelHtml;\n\n// Rebuild content with pixel injected\nconst finalContent = [{ text: JSON.stringify({ subject: parsed.subject, body: finalBody }) }];\n\nlet urls = [];\nif (body.attachmentUrls) {\n  try { urls = JSON.parse(body.attachmentUrls); } catch(e) { urls = []; }\n}\n\nconst baseUrl = 'https://buys-therapist-music-assistant.trycloudflare.com';\n\nreturn [{\n  json: {\n    email: body.email,\n    content: finalContent,\n    hasAttachments: urls.length > 0,\n    attachmentUrls: urls.map(u => baseUrl + u)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [

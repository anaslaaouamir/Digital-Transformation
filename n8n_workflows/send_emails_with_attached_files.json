      "id": "f868d431-b51a-4167-9895-033ebd2ad1d9",
      "name": "Download File"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst first = items[0].json;\n\nconst binaryData = {};\nitems.forEach((item, index) => {\n  if (item.binary) {\n    Object.keys(item.binary).forEach(key => {\n      binaryData[`attachment_${index}`] = item.binary[key];\n    });\n  }\n});\n\nreturn [{\n  json: {\n    email: first.email,\n    subject: first.subject,\n    body: first.body\n  },\n  binary: binaryData\n}];"
      },
      "type": "n8n-nodes-base.code",

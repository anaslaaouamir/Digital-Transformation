      "id": "fc31f034-767f-4d2b-af8e-ed323fb1dde8",
      "name": "Has Attachments?"
    },
    {
      "parameters": {
        "jsCode": "// Split each attachment URL into its own item so HTTP Request loops over them\nconst item = $input.first().json;\nreturn item.attachmentUrls.map(url => ({\n  json: {\n    email: item.email,\n    subject: item.subject,\n    body: item.body,\n    attachmentUrl: url,\n    fileName: url.split('/').pop()\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",

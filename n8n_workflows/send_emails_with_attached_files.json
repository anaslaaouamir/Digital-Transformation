      "webhookId": "7c01862c-efed-43ac-b9f4-21e5a0037997",
      "retryOnFail": false
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Parse attachmentUrls if present (comes as JSON string from Java)\nlet urls = [];\nif (body.attachmentUrls) {\n  try {\n    urls = JSON.parse(body.attachmentUrls);\n  } catch(e) {\n    urls = [];\n  }\n}\n\n// Base URL of your Spring Boot server (Cloudflare tunnel or localhost)\nconst baseUrl = 'https://buys-therapist-music-assistant.trycloudflare.com';\n\nreturn [{\n  json: {\n    email: body.email,\n    subject: body.subject,\n    body: body.body,\n    hasAttachments: urls.length > 0,\n    attachmentUrls: urls.map(u => baseUrl + u)\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -448,
        128
      ],
      "id": "5570dbac-1778-4cc0-b7e0-a05616b1a50b",
      "name": "Parse Body"
    },
    {
